# Arkade network to use in the browser wallet.
VITE_ARKADE_NETWORK=mutinynet

# Optional overrides for custom infrastructure.
# VITE_ARKADE_SERVER_URL=https://mutinynet.arkade.sh
# VITE_BOLTZ_API_URL=https://api.boltz.mutinynet.arkade.sh
# VITE_ESPLORA_URL=

# Optional base path when the app is hosted under a subpath, such as a
# GitHub Pages project site. Leave unset for local dev or user sites.
# VITE_PUBLIC_BASE_PATH=
