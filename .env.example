# Arkade Wallet Configuration

# Network: bitcoin | mutinynet | signet | regtest
ARKADE_NETWORK=mutinynet

# Override defaults (optional)
# ARKADE_SERVER_URL=https://mutinynet.arkade.sh
# BOLTZ_API_URL=https://api.boltz.mutinynet.arkade.sh

# Server port
PORT=3001

# Data directory (default: ~/.arkade-wallet)
# ARKADE_DATA_DIR=

# Allowed browser origins for the frontend, comma-separated.
# For GitHub Pages project sites, use the origin only, not the repo path.
# Example: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-user.github.io
CORS_ALLOWED_ORIGINS=http://localhost:5173
